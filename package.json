{
  "name": "aemijs",
  "version": "1.0.0",
  "description": "A tiny, dependency-free, cross-runtime toolkit of bleeding-edge vanilla JavaScript. Run functions off-thread anywhere, plus a few fun helpers the platform still lacks.",
  "type": "module",
  "license": "MIT",
  "sideEffects": false,
  "engines": {
    "node": ">=22"
  },
  "exports": {
    ".": "./src/core/index.js",
    "./workers": "./src/core/workers.js",
    "./fp": "./src/core/fp.js",
    "./math": "./src/core/math.js",
    "./data": "./src/core/data.js",
    "./bench": "./src/core/bench.js",
    "./rand": "./src/core/rand.js",
    "./hash": "./src/core/hash.js",
    "./struct": "./src/core/struct.js",
    "./dom": {
      "browser": "./src/dom/index.js",
      "default": "./src/dom/index.js"
    }
  },
  "files": [
    "src",
    "dist",
    "README.md"
  ],
  "scripts": {
    "lint": "bunx eslint src test bench scripts",
    "test": "bun test test/",
    "test:node": "node --test",
    "test:bun": "bun test test/",
    "test:deno": "deno test --allow-read --allow-net --allow-env",
    "build": "bun scripts/build.js",
    "prepack": "bun run build",
    "bench": "bun bench/run.mjs",
    "check": "bun run lint && bun run test && bun run test:node && bun run test:deno"
  },
  "keywords": [
    "worker",
    "worker-threads",
    "cross-runtime",
    "multithread",
    "off-thread",
    "esm",
    "vanilla-js",
    "deno",
    "bun",
    "csv",
    "easing",
    "bigint"
  ],
  "devDependencies": {
    "@eslint/js": "^9.39.0",
    "comlink": "^4.4.2",
    "denque": "^2.1.0",
    "eslint": "^9.39.0",
    "happy-dom": "^20.0.0",
    "lru-cache": "^11.0.0",
    "mitata": "^1.0.34",
    "papaparse": "^5.5.3",
    "udsv": "^0.7.3",
    "xxhash-wasm": "^1.1.0"
  }
}
